# Kova IDE Environment Variables Template
# Copy this to .env (do not commit .env to git)

# ── Backend ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
KOVA_API_URL=http://localhost:3001

# ── Supabase ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=

# ── AI Providers ─────────────────────────────────────────────────────────
GROQ_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Services ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ── Feature Flags ────────────────────────────────────────────────────────
ENABLE_TELEMETRY=false
ENABLE_AUTO_UPDATE=true
DEBUG_MODE=false
